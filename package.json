{
  "name": "open-youtube-transcript-copy",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Unofficial open fork and provenance-tracked source extraction for YouTube Transcript Copy.",
  "scripts": {
    "test": "node --test",
    "sync:local": "node scripts/update-from-amo.mjs",
    "sync:github": "gh workflow run update-from-amo.yml",
    "update:amo": "node scripts/update-from-amo.mjs",
    "build:extension": "node scripts/validate-manifest.mjs && node scripts/build-extension.mjs",
    "build": "node scripts/build-extension.mjs",
    "validate:manifest": "node scripts/validate-manifest.mjs",
    "release:github": "npm run build:extension && node scripts/release-github.mjs",
    "publish:amo": "npm run build:extension && npx web-ext sign --source-dir source/extension --artifacts-dir dist --channel listed"
  },
  "dependencies": {
    "yauzl": "^3.2.0"
  },
  "devDependencies": {}
}
