{
  "manifest_version": 3,
  "name": "open-youtube-transcript-copy",
  "version": "1.0.7",
  "description": "Unofficial open fork of YouTube Transcript Copier. Adds a 'Copy Transcript' button with settings next to the subscribe button on YouTube video pages.",
  "permissions": [
    "storage",
    "clipboardWrite"
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "open-youtube-transcript-copy@stone-w4tch3r.github.io"
    }
  }
}
